<?xml version="1.0" encoding="UTF-16"?>
<!--
  Tarea de Windows Task Scheduler para AllDataTennis daily-sync.

  INSTALACION (ejecutar en PowerShell como Administrador):
    Register-ScheduledTask -Xml (Get-Content ".\daily-sync-task.xml" -Raw) -TaskName "AllDataTennis-DailySync" -Force

  O desde la interfaz grafica:
    1. Abrir "Programador de tareas" (taskschd.msc)
    2. Accion > Importar tarea > seleccionar este archivo
-->
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Date>2026-04-05T00:00:00</Date>
    <Author>AllDataTennis</Author>
    <Description>Pipeline diario: ingesta de partidos, resolucion de predicciones y recalibracion de factores.</Description>
    <URI>\AllDataTennis\DailySync</URI>
  </RegistrationInfo>

  <Triggers>
    <CalendarTrigger>
      <StartBoundary>2026-04-06T06:00:00</StartBoundary>
      <Enabled>true</Enabled>
      <ScheduleByDay>
        <DaysInterval>1</DaysInterval>
      </ScheduleByDay>
    </CalendarTrigger>
  </Triggers>

  <Principals>
    <Principal id="Author">
      <!-- Cambiar al usuario de Windows que ejecuta el servidor Next.js -->
      <UserId>antonio.desolis</UserId>
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>

  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>  <!-- Si el PC estaba apagado, ejecutar al encender -->
    <RunOnlyIfNetworkAvailable>false</RunOnlyIfNetworkAvailable>
    <IdleSettings>
      <StopOnIdleEnd>false</StopOnIdleEnd>
      <RestartOnIdle>false</RestartOnIdle>
    </IdleSettings>
    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <WakeToRun>false</WakeToRun>
    <ExecutionTimeLimit>PT10M</ExecutionTimeLimit>  <!-- Timeout maximo: 10 minutos -->
    <Priority>7</Priority>
  </Settings>

  <Actions Context="Author">
    <Exec>
      <Command>powershell.exe</Command>
      <Arguments>-NonInteractive -NoProfile -ExecutionPolicy Bypass -File "C:\Users\antonio.desolis\alldatatennis\scripts\daily-sync.ps1"</Arguments>
      <WorkingDirectory>C:\Users\antonio.desolis\alldatatennis\scripts</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
